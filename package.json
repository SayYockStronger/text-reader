{
  "name": "text-reader",
  "displayName": "日本語読み上げ",
  "description": "テキストファイルを日本語で読み上げるVS Code拡張機能。ユーザー辞書・詳細設定・音声/速度/音量の自動保存・設定のJSON移行に対応。",
  "version": "0.0.1",
  "publisher": "SayYockStronger",
  "license": "MIT",
  "icon": "images/icon.png",
  "keywords": [
    "tts",
    "text-to-speech",
    "japanese",
    "読み上げ",
    "音声",
    "kuromoji",
    "辞書",
    "小説"
  ],
  "galleryBanner": {
    "color": "#2b2d30",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "text-reader",
          "title": "日本語読み上げ",
          "icon": "$(unmute)"
        }
      ]
    },
    "views": {
      "text-reader": [
        {
          "type": "webview",
          "id": "text-reader.view",
          "name": "プレーヤー"
        },
        {
          "id": "text-reader.files",
          "name": "ファイル"
        }
      ]
    },
    "commands": [
      {
        "command": "text-reader.selectFile",
        "title": "日本語読み上げ: ファイルを選択"
      },
      {
        "command": "text-reader.openFile",
        "title": "日本語読み上げ: ファイルを開く"
      },
      {
        "command": "text-reader.refreshFiles",
        "title": "更新",
        "icon": "$(refresh)"
      },
      {
        "command": "text-reader.readAll",
        "title": "日本語読み上げ: ファイル全体を読み上げ"
      },
      {
        "command": "text-reader.readFromCursor",
        "title": "日本語読み上げ: カーソル位置から読み上げ"
      },
      {
        "command": "text-reader.pauseResume",
        "title": "日本語読み上げ: 一時停止/再開"
      },
      {
        "command": "text-reader.stop",
        "title": "日本語読み上げ: 停止"
      },
      {
        "command": "text-reader.setSpeed",
        "title": "日本語読み上げ: 読み上げ速度を設定"
      },
      {
        "command": "text-reader.openAdvancedSettings",
        "title": "日本語読み上げ: 詳細設定を開く"
      },
      {
        "command": "text-reader.openUserDictionary",
        "title": "日本語読み上げ: ユーザー辞書を開く"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "text-reader.refreshFiles",
          "when": "view == text-reader.files",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "text-reader.readAll",
        "key": "ctrl+alt+r",
        "when": "editorTextFocus"
      },
      {
        "command": "text-reader.readFromCursor",
        "key": "ctrl+alt+shift+r",
        "when": "editorTextFocus"
      },
      {
        "command": "text-reader.pauseResume",
        "key": "ctrl+alt+p"
      },
      {
        "command": "text-reader.stop",
        "key": "ctrl+alt+s"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/kuromoji": "^0.1.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "kuromoji": "^0.1.2"
  },
  "bundledDependencies": [
    "kuromoji"
  ]
}
